# 公開HPの公開URL（既存）
NEXT_PUBLIC_SITE_URL=https://hassamu-izumi.vercel.app

# ヘッドレスWordPress連携（Sprint 1で本番接続予定）
# 未設定（空）のあいだは src/lib/mockWpData.ts のフォールバックを返します。
WP_API_BASE_URL=http://hassamu-izumi-cms.local/wp-json/wp/v2

# WP Application Password 認証（公開エンドポイントのみ叩く間は空でOK）
# 下書きプレビューや非公開CPTを取得し始めるタイミングで設定。
WP_API_USERNAME=
WP_API_APP_PASSWORD=
